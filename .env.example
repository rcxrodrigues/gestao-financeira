# ════════════════════════════════════════════════════════════════════
# CONFIGURAÇÃO - copie para .env.local e preencha os valores
# Pegue esses valores no painel do Supabase em Project Settings → API
# ════════════════════════════════════════════════════════════════════

# URL pública do projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co

# Chave pública (anon) — pode ser exposta no frontend
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx...

# Chave service_role — NUNCA exponha publicamente, usada só em rotas server-side
# Tem permissão total no banco, ignora RLS. Necessária para o painel admin.
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx...
